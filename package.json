{
  "name": "appuama-racing-desktop",
  "version": "1.0.0",
  "description": "Aplicativo Desktop Offline-First da equipe Apuama",
  "author": "Mateus",
  "main": "main.js",
  "scripts": {
    "frontend:build": "cd frontend-apuama && npm run build",
    "electron:dev": "electron . --no-sandbox",
    "electron:build:win": "npm run frontend:build && electron-builder build --win --publish never",
    "electron:build:linux": "npm run frontend:build && electron-builder build --linux --publish never",
    "electron:build": "npm run electron:build:win"
  },
  "build": {
    "appId": "com.appuama.racing",
    "productName": "APPuama Racing",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend-apuama/out/**/*"
    ],
    "icon": "frontend-apuama/public/Logo_APU.png",
    "win": {
      "icon": "frontend-apuama/public/Logo_APU.ico",
      "target": "portable"
    },
    "linux": {
      "icon": "frontend-apuama/public/Logo_APU.svg",
      "category": "Utility",
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  }
}
